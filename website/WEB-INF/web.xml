<?xml version="1.0" encoding="UTF-8"?>

<!--
    web.xml
    Deployment descriptor for the secure web application.
    This file defines servlets, URL mappings, filters, and session configuration.
-->

<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

  <!-- ========================= -->
  <!-- Login Servlet Configuration -->
  <!-- Handles user authentication -->
  <!-- ========================= -->

  <servlet>
    <servlet-name>LoginServlet</servlet-name>
    <servlet-class>LoginServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>LoginServlet</servlet-name>
    <url-pattern>/login</url-pattern>
  </servlet-mapping>


  <!-- ========================= -->
  <!-- About Me Servlet -->
  <!-- Displays user information after login -->
  <!-- ========================= -->

  <servlet>
    <servlet-name>AboutMeServlet</servlet-name>
    <servlet-class>AboutMeServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>AboutMeServlet</servlet-name>
    <url-pattern>/aboutme</url-pattern>
  </servlet-mapping>


  <!-- ========================= -->
  <!-- Logout Servlet -->
  <!-- Terminates user session -->
  <!-- ========================= -->

  <servlet>
    <servlet-name>LogoutServlet</servlet-name>
    <servlet-class>LogoutServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>LogoutServlet</servlet-name>
    <url-pattern>/logout</url-pattern>
  </servlet-mapping>


  <!-- ========================= -->
  <!-- Courses Servlet -->
  <!-- Displays course-related content -->
  <!-- ========================= -->

  <servlet>
    <servlet-name>coursesServlet</servlet-name>
    <servlet-class>coursesServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>coursesServlet</servlet-name>
    <url-pattern>/courses</url-pattern>
  </servlet-mapping>


  <!-- ========================= -->
  <!-- Image Servlet -->
  <!-- Securely serves protected images from WEB-INF -->
  <!-- Prevents direct access to image files -->
  <!-- ========================= -->

  <servlet>
    <servlet-name>ImageServlet</servlet-name>
    <servlet-class>ImageServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>ImageServlet</servlet-name>
    <url-pattern>/image</url-pattern>
  </servlet-mapping>


  <!-- ========================= -->
  <!-- Authentication Filter -->
  <!-- Intercepts requests and ensures the user is logged in -->
  <!-- Applied to all URLs -->
  <!-- ========================= -->

  <filter>
    <filter-name>AuthFilter</filter-name>
    <filter-class>AuthFilter</filter-class>
  </filter>

  <filter-mapping>
    <filter-name>AuthFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>


  <!-- ========================= -->
  <!-- Session Configuration -->
  <!-- Session timeout set to 1 minute for security demonstration -->
  <!-- ========================= -->

  <session-config>
    <session-timeout>1</session-timeout>
  </session-config>

</web-app>